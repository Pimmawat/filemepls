# --- HTTP server ---
HTTP_ADDR=:8080
FRONTEND_BASE_URL=http://localhost:3000
DEFAULT_LOCALE=th
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Database ---
# Local dev: a Postgres instance running on the same machine.
# Production: point at the real DB host (and use a strong password).
DATABASE_URL=postgres://filemepls:filemepls@localhost:5432/filemepls?sslmode=disable

# --- JWT session ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL=24h

# --- Storage ---
STORAGE_ROOT=./data/storage
# MAX_UPLOAD_SIZE in bytes; 0 (or unset) means unlimited.
MAX_UPLOAD_SIZE=0
# Comma-separated list of allowed mime types, e.g.
#   image/png,image/jpeg,application/pdf
# "*" allows any mime type.
ALLOWED_MIMES=*

# --- OAuth: GitHub ---
# Create an OAuth App at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8080/api/auth/github/callback

# --- OAuth: Google ---
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback
