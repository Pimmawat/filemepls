# Template for a native Windows deployment (no Docker). Copy to backend\.env
# on the server and fill in the real values before running deploy.ps1.
#
# REPLACE_WITH_SERVER_HOST below with the server's actual LAN/public
# hostname or IP (e.g. 192.168.1.50 or files.example.com) — NOT localhost.
# Browsers on other machines resolve "localhost" to themselves, not to this
# server, so leaving it as localhost will work only from the server itself.

# --- HTTP server ---
HTTP_ADDR=:8080
FRONTEND_BASE_URL=http://REPLACE_WITH_SERVER_HOST:3000
DEFAULT_LOCALE=th
CORS_ALLOWED_ORIGINS=http://REPLACE_WITH_SERVER_HOST:3000

# --- Database ---
# Native Postgres on Windows, listening on the default port.
DATABASE_URL=postgres://postgres:secret@localhost:5432/filemepls?sslmode=disable

# --- JWT session ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL=24h

# --- Storage ---
# A real Windows path. The service account running filemepls-api.exe needs
# write access to this directory (and it will be created if missing).
STORAGE_ROOT=C:\filemepls\storage
MAX_UPLOAD_SIZE=0
ALLOWED_MIMES=*

# --- OAuth: GitHub ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://REPLACE_WITH_SERVER_HOST:8080/api/auth/github/callback

# --- OAuth: Google ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://REPLACE_WITH_SERVER_HOST:8080/api/auth/google/callback
